<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260217000000-1" author="codex">
        <createTable tableName="debt_item_type">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(120)">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="datetime(6)">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="datetime(6)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="20260217000000-2" author="codex">
        <addUniqueConstraint
            tableName="debt_item_type"
            columnNames="name"
            constraintName="ux_debt_item_type_name"/>

        <createIndex tableName="debt_item_type" indexName="idx_debt_item_type_active">
            <column name="active"/>
        </createIndex>

        <createIndex tableName="debt_item_type" indexName="idx_debt_item_type_sort_order">
            <column name="sort_order"/>
        </createIndex>
    </changeSet>

    <changeSet id="20260217000000-3" author="codex">
